{
  "name": "tables-vscode-ext",
  "displayName": "Tables CSV Editor",
  "description": "View and edit CSV files with a modern data grid inside VS Code.",
  "version": "0.0.1",
  "publisher": "bagaking",
  "repository": {
    "type": "git",
    "url": "https://github.com/bagaking/tables-vscode-ext.git"
  },
  "bugs": {
    "url": "https://github.com/bagaking/tables-vscode-ext/issues"
  },
  "homepage": "https://github.com/bagaking/tables-vscode-ext#readme",
  "engines": {
    "vscode": "^1.84.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCustomEditor:tables.csvEditor",
    "onCommand:tablesCsvEditor.openFile",
    "onCommand:tablesCsvEditor.exportMarkdown",
    "onCommand:tablesCsvEditor.runDiagnostics",
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "mocha -r ts-node/register tests/**/*.test.ts",
    "vscode:prepublish": "npm run compile && node scripts/copy-vendor.js",
    "package:vsix": "npx vsce package",
    "install:local": "sh -c 'code --install-extension \"$(ls -t *.vsix | head -n1)\"'",
    "publish:marketplace": "npx vsce publish",
    "publish:marketplace:patch": "npm version patch && npx vsce publish",
    "publish:marketplace:minor": "npm version minor && npx vsce publish",
    "publish:marketplace:major": "npm version major && npx vsce publish",
    "publish:openvsx": "npx ovsx publish -p $OVSX_TOKEN",
    "release:package": "npm run compile && npm run package:vsix",
    "release:patch": "npm run compile && npm run publish:marketplace:patch",
    "release:minor": "npm run compile && npm run publish:marketplace:minor",
    "release:major": "npm run compile && npm run publish:marketplace:major"
  },
  "contributes": {
    "commands": [
      {
        "command": "tablesCsvEditor.openFile",
        "category": "Tables",
        "title": "Open CSV in Tables Editor"
      },
      {
        "command": "tablesCsvEditor.exportMarkdown",
        "category": "Tables",
        "title": "Export CSV as GFM Markdown"
      },
      {
        "command": "tablesCsvEditor.runDiagnostics",
        "category": "Tables",
        "title": "Run Diagnostics (Tables CSV Editor)"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "tablesCsvEditor.exportMarkdown",
          "when": "resourceExtname == .csv",
          "group": "navigation@2"
        }
      ],
      "commandPalette": [
        {
          "command": "tablesCsvEditor.exportMarkdown"
        },
        {
          "command": "tablesCsvEditor.runDiagnostics"
        }
      ]
    },
    "customEditors": [
      {
        "viewType": "tables.csvEditor",
        "displayName": "Tables CSV Editor",
        "selector": [
          {
            "filenamePattern": "*.csv"
          }
        ],
        "priority": "default"
      }
    ]
  },
  "devDependencies": {
    "@types/chai": "^4.3.11",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.11.30",
    "@types/papaparse": "^5.3.16",
    "@types/vscode": "^1.84.0",
    "chai": "^4.4.1",
    "mocha": "^10.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "ovsx": "^0.8.3",
    "vsce": "^2.15.0"
  },
  "dependencies": {
    "@khgame/tables": "0.2.8",
    "ag-grid-community": "^32.2.1",
    "papaparse": "^5.4.1"
  },
  "license": "MIT"
}
